# คัดลอกไฟล์นี้เป็น .env แล้วใส่คีย์จริง:  cp .env.example .env
# (ไฟล์ .env จริงถูก gitignore ไว้ ไม่ขึ้น git)
GEMINI_API_KEY=your-key-here

# (ไม่บังคับ) ส่ง daily/weekly/monthly report เข้า Discord — สร้าง Incoming Webhook ใน
# Discord: Channel Settings > Integrations > Webhooks > New Webhook > Copy URL
# ถ้าไม่ตั้ง ระบบจะข้ามการส่งเงียบๆ
DISCORD_WEBHOOK_URL=

# (ไม่บังคับ) ช่องแยกสำหรับ Phase 4 quality alert (extraction accuracy ต่ำผิดปกติ) —
# คนละหัวข้อกับ report หลัก (นั่นคือ "หุ้นน่าสนใจไหม", นี่คือ "ระบบคำนวณถูกไหม") แนะนำให้ใช้
# webhook ของอีกช่อง (เช่น #dev-alerts) แยกจาก #stock-research — เงียบถ้าทุกตัวปกติหรือไม่ตั้งค่า
DISCORD_WEBHOOK_URL_QUALITY=

# (ไม่บังคับ) ช่องแยกสำหรับ Phase 5.5 portfolio alert — เงื่อนไขออกที่โดนแตะ 'เฉพาะโพซิชันที่
# ถืออยู่จริง' (ไม่ใช่แค่จับตา) เป็นสัญญาณที่ต้องรู้ทันที แนะนำตั้ง push notification เฉพาะ
# ช่องนี้ (ต่างจาก #stock-research ที่เช็ควันละครั้งพอ) — เงียบถ้าไม่มี breach หรือไม่ตั้งค่า
DISCORD_WEBHOOK_URL_PORTFOLIO=