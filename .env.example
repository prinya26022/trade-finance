# คัดลอกไฟล์นี้เป็น .env แล้วใส่คีย์จริง:  cp .env.example .env
# (ไฟล์ .env จริงถูก gitignore ไว้ ไม่ขึ้น git)
GEMINI_API_KEY=your-key-here

# (ไม่บังคับ) ส่ง daily report เข้า Discord — สร้าง Incoming Webhook ใน
# Discord: Channel Settings > Integrations > Webhooks > New Webhook > Copy URL
# ถ้าไม่ตั้ง ระบบจะข้ามการส่งเงียบๆ
DISCORD_WEBHOOK_URL=